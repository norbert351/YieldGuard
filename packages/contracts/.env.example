# YieldGuard Contracts — Environment Variables

# ── XLayer Deployment ──
# Add your private key for deploying to XLayer testnet/mainnet
PRIVATE_KEY=your_private_key_here

# XLayer RPC URLs
XLAYER_MAINNET_RPC=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech

# Optional: Block explorer API key for contract verification
XLAYERSCAN_API_KEY=
